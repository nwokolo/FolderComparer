<Window x:Class="FolderComparer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FolderComparer"
        xmlns:conv="clr-namespace:FolderComparer.Converters"
        xmlns:vm="clr-namespace:FolderComparer.ViewModels"
        mc:Ignorable="d"
        Title="Folder Comparer" Height="700" Width="1100" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor" />
        <conv:FileSizeConverter x:Key="FileSize" />
        <conv:DateTimeConverter x:Key="DateTime" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Source Path -->
        <GroupBox Header="Source Folder" Grid.Row="0" Padding="8" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" FontSize="13"
                         IsEnabled="{Binding IsNotComparing}" />
                <Button Content="Browse..." Grid.Column="1" Margin="8,0,0,0" Padding="12,4"
                        Command="{Binding BrowseSourceCommand}" IsEnabled="{Binding IsNotComparing}" />
            </Grid>
        </GroupBox>

        <!-- Destination Path -->
        <GroupBox Header="Destination Folder" Grid.Row="1" Padding="8" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" FontSize="13"
                         IsEnabled="{Binding IsNotComparing}" />
                <Button Content="Browse..." Grid.Column="1" Margin="8,0,0,0" Padding="12,4"
                        Command="{Binding BrowseDestinationCommand}" IsEnabled="{Binding IsNotComparing}" />
            </Grid>
        </GroupBox>

        <!-- Recent Pairs -->
        <GroupBox Header="Recent Sync Pairs" Grid.Row="2" Padding="8" Margin="0,0,0,4">
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox ItemsSource="{Binding RecentPairs}"
                  SelectedItem="{Binding SelectedRecentPair}"
                  DisplayMemberPath="DisplayText"
                  IsEnabled="{Binding IsNotComparing}"
                  MinWidth="380"
                  VerticalContentAlignment="Center" />

            <Button Content="Use Pair" Grid.Column="1" Margin="8,0,0,0" Padding="12,4"
                Command="{Binding UseRecentPairCommand}"
                IsEnabled="{Binding IsNotComparing}" />
            <Button Content="Compare" Grid.Column="2" Margin="8,0,0,0" Padding="12,4"
                Command="{Binding CompareRecentPairCommand}"
                IsEnabled="{Binding IsNotComparing}" />
            <Button Content="Sync Both" Grid.Column="3" Margin="8,0,0,0" Padding="12,4"
                Command="{Binding SyncRecentPairCommand}"
                IsEnabled="{Binding IsNotComparing}" />
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,8">
            <Button Content="Compare" Command="{Binding CompareCommand}"
                    Padding="20,6" FontSize="14" FontWeight="SemiBold" />
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    Padding="20,6" FontSize="14" Margin="8,0,0,0"
                    Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Sync Options -->
        <GroupBox Header="Sync Options" Grid.Row="4" Padding="8" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <CheckBox Content="Overwrite mismatches" IsChecked="{Binding OverwriteMismatches}" 
                          VerticalAlignment="Center" Margin="0,0,20,0"
                          IsEnabled="{Binding IsNotComparing}" />
                
                <Button Content="Sync Both →" Command="{Binding SyncBidirectionalCommand}"
                        Padding="12,4" Grid.Column="1" Margin="0,0,8,0"
                        IsEnabled="{Binding IsNotComparing}" />
                
                <Button Content="→ Destination" Command="{Binding SyncSourceToDestCommand}"
                        Padding="12,4" Grid.Column="2" Margin="0,0,8,0"
                        IsEnabled="{Binding IsNotComparing}" />
                
                <Button Content="← Source" Command="{Binding SyncDestToSourceCommand}"
                        Padding="12,4" Grid.Column="3"
                        IsEnabled="{Binding IsNotComparing}" />
            </Grid>
        </GroupBox>

        <!-- Filters -->
        <Grid Grid.Row="5" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <CheckBox Content="Match" IsChecked="{Binding ShowMatches}" Margin="0,0,10,0" VerticalAlignment="Center" />
                <CheckBox Content="Source only" IsChecked="{Binding ShowSourceOnly}" Margin="0,0,10,0" VerticalAlignment="Center" />
                <CheckBox Content="Dest only" IsChecked="{Binding ShowDestOnly}" Margin="0,0,10,0" VerticalAlignment="Center" />
                <CheckBox Content="Different" IsChecked="{Binding ShowDifferent}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBox Grid.Column="1" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="12,0,0,0" VerticalContentAlignment="Center" />
            <TextBlock Grid.Column="2" Text="{Binding SummaryText}" VerticalAlignment="Center"
                       Margin="12,0,0,0" FontWeight="SemiBold" />
        </Grid>

        <!-- Results DataGrid -->
        <DataGrid Grid.Row="6" ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F5F5F5"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                  CanUserSortColumns="True" CanUserReorderColumns="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Relative Path" Binding="{Binding RelativePath}" Width="*" MinWidth="200" />
                <DataGridTextColumn Header="Status" Width="130" MinWidth="100">
                    <DataGridTextColumn.Binding>
                        <Binding Path="StatusDescription" />
                    </DataGridTextColumn.Binding>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource StatusToColor}}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Source Size" Binding="{Binding SourceSize, Converter={StaticResource FileSize}}" Width="100" />
                <DataGridTextColumn Header="Dest Size" Binding="{Binding DestinationSize, Converter={StaticResource FileSize}}" Width="100" />
                <DataGridTextColumn Header="Source Modified" Binding="{Binding SourceLastModified, Converter={StaticResource DateTime}}" Width="150" />
                <DataGridTextColumn Header="Dest Modified" Binding="{Binding DestinationLastModified, Converter={StaticResource DateTime}}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="7" Margin="0,6,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
